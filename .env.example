# a16zee — secrets schema
#
# copy this file to .env, fill in real values, then push to github actions
# secrets with:
#
#   gh lockbox dotenv push .env
#
# pull the current remote state into a fresh .env with:
#
#   gh lockbox dotenv pull
#
# .env is .gitignored. .env.example (this file) is committed as documentation.

# cloudflare api token. used by .github/workflows/{deploy,preview}.yml to
# deploy to cloudflare pages. minimum scope for CI: account → cloudflare pages → edit.
# create one at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# cloudflare account id. visible in any cloudflare dashboard URL (the long hex string).
# not strictly secret but workflows expect `secrets.CLOUDFLARE_ACCOUNT_ID`.
CLOUDFLARE_ACCOUNT_ID=
